{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/token",
    "headers": {
      "Authorization": {
        "matches": "Basic (TUFLSVRJOnBhc3N3b3Jk|TUFLSVRJMjpwYXNzd29yZA==)"
    },
      "Content-Type": {
        "contains": "application/x-www-form-urlencoded"
      }
    },
    "bodyPatterns": [
      {
        "contains": "grant_type=client_credentials"
      }
    ]
  },
  "response": {
    "status": 200,
    "transformers": ["response-template"],
    "headers": {
      "Content-Type": "application/json"
    },
    "body": "{ \"access_token\": \"{{randomValue type='UUID'}}\", \"token_type\": \"Bearer\", \"expires_in\": 3600, \"scope\": \"am_application_scope defaults\" }"
  }
}