{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/token",
    "headers": {
      "Authorization": {
        "equalTo": "Basic TUFLSVRJOnBhc3N3b3Jk"
      },
      "Content-Type": {
        "contains": "application/x-www-form-urlencoded"
      }
    },
    "bodyPatterns": [
      {
        "contains": "grant_type=client_credentials"
      }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "access_token": "mock_access_token",
      "token_type": "Bearer",
      "expires_in": 3600,
      "scope": "payments"
    }
  }
}