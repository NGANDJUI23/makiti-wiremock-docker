{
    "priority": 5,
    "request": {
        "method": "POST",
        "url": "/omcoreapis/1.0.2/mp/pay",
        "headers": {
            "Authorization": {
                "matches": "Bearer mock_access_token"
            },
            "X-AUTH-TOKEN": {
                "matches": "AZERTY1234567890"
            },
            "Content-Type": {
                "contains": "application/json"
            }
        },
        "bodyPatterns": [
            { "matchesJsonPath": "$.subscriberMsisdn" },
            { "matchesJsonPath": "$.channelUserMsisdn" },
            { "matchesJsonPath": "$.amount" },
            { "matchesJsonPath": "$.description" },
            { "matchesJsonPath": "$.orderId" },
            { "matchesJsonPath": "$.pin" },
            { "matchesJsonPath": "$[?(@.payToken != 'mock_pay_token')]" },
            { "matchesJsonPath": "$.notifUrl" }
        ]
    },
    "response": {
        "status": 401,
        "headers": {
            "Content-Type": "application/json"
        },
        "jsonBody": {
            "error": "Unauthorized",
            "message": "Invalid payToken in body"
        }
    }
}